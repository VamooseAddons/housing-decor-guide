<Ui xmlns="http://www.blizzard.com/wow/ui/"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!--
        HDGR_SettingsExpandTemplate
        Inherits SettingsExpandableSectionTemplate for collapsible section
        headers inside the Housing Decor Guide Settings panel.
        Mixes in HDGR_SettingsExpandSectionMixin (overrides Init,
        OnExpandedChanged, CalculateHeight). virtual="true": not instantiated
        directly; used as template via CreateSettingsExpandableSectionInitializer.
    -->
    <Frame name="HDGR_SettingsExpandTemplate"
           inherits="SettingsExpandableSectionTemplate"
           mixin="HDGR_SettingsExpandSectionMixin"
           virtual="true">
        <Size y="24" />
    </Frame>

    <!--
        HDGR_SettingsCheckRowTemplate
        Checkbox-on-the-LEFT settings row (Delves-Helper style) vs Blizzard's
        default centre-anchored checkbox + left-column label (which truncated
        our longer names). Inherits the stock element base and, via
        HDGR_SettingsCheckRowMixin (a subclass of SettingsCheckboxControlMixin),
        keeps ALL the binding / tooltip / enable-state behaviour; only the two
        anchors change. Bound to a setting via Settings.CreateControlInitializer.
    -->
    <Frame name="HDGR_SettingsCheckRowTemplate"
           inherits="SettingsListElementTemplate"
           mixin="HDGR_SettingsCheckRowMixin"
           virtual="true">
        <Size x="280" y="26" />
        <Scripts>
            <OnLoad method="OnLoad"/>
        </Scripts>
    </Frame>

</Ui>
